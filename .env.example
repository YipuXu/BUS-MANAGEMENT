# AWS 凭证配置
# 从 AWS IAM 控制台获取 Access Key 和 Secret Key
# https://console.aws.amazon.com/iam/

AWS_ACCESS_KEY_ID=你的AccessKeyID
AWS_SECRET_ACCESS_KEY=你的SecretAccessKey
AWS_REGION=us-east-1

# DeepSeek API 配置
# 从 DeepSeek 开放平台获取 API Key
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=你的DeepSeekAPIKey
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 其他配置（可选）
# OCR_ENGINE=aws_textract  # 可选: pymupdf, aws_textract, google_vision, rapidocr
